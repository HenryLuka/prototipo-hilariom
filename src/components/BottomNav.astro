---
const currentPath = Astro.url.pathname;
const navItems = [
  { path: '/prototipo-hilariom/', label: 'Home', icon: '<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>' },
  { path: '/prototipo-hilariom/obras/', label: 'Obras', icon: '<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="14" x2="23" y2="14"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="14" x2="4" y2="14"></line></svg>' },
  { path: '/prototipo-hilariom/produtos/', label: 'Produtos', icon: '<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"></line><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>' },
  { path: '/prototipo-hilariom/contato/', label: 'Contato', icon: '<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>' },
];
---

<nav class="bottom-nav">
  <div class="nav-container">
    {navItems.map((item) => {
      // Fix active check since the root path is now /prototipo-hilariom/
      const isActive = currentPath === item.path || (item.path !== '/prototipo-hilariom/' && currentPath.startsWith(item.path));
      
      return (
        <a href={item.path} class={`nav-item ${isActive ? 'active' : ''}`}>
          <div class="nav-icon" set:html={item.icon} />
          <span class="nav-label">{item.label}</span>
        </a>
      )
    })}
  </div>
</nav>

<style>
  .bottom-nav {
    position: fixed;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 32px);
    max-width: 420px;
    height: var(--nav-height);
    background: #ffffff;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    z-index: 50;
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 24px;
    overflow: hidden;
  }
  
  /* Slight adjustments on desktop */
  @media (min-width: 768px) {
    .bottom-nav {
      bottom: 24px;
      background: #ffffff;
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
    }
  }

  .nav-container {
    display: flex;
    justify-content: space-around;
    align-items: center;
    height: 100%;
    padding: 0 8px;
  }

  .nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #000000;
    min-width: 64px;
    height: 100%;
    transition: all 0.2s ease-in-out;
    padding-top: 4px;
  }

  .nav-icon {
    margin-bottom: 2px;
    transition: transform 0.2s ease;
  }

  .nav-label {
    font-size: 0.65rem;
    font-weight: 500;
  }

  .nav-item.active {
    color: #eab308; /* Amarelo com bom contraste no fundo branco */
  }

  .nav-item.active .nav-icon {
    transform: translateY(-2px);
  }
  
  .nav-item:active .nav-icon {
    transform: scale(0.9);
  }
</style>
