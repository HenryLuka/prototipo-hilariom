---
const currentPath = Astro.url.pathname;
const navItems = [
  { path: '/', label: 'Home', icon: '<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>' },
  { path: '/obras', label: 'Obras', icon: '<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="14" x2="23" y2="14"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="14" x2="4" y2="14"></line></svg>' },
  { path: '/produtos', label: 'Produtos', icon: '<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"></line><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>' },
  { path: '/contato', label: 'Contato', icon: '<svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>' },
];
---

<aside class="sidebar-nav">
  <div class="sidebar-logo">
    <!-- Tentando usar o logo com texto, se não tiver carrega o ícone normal -->
    <a href="/prototipo-hilariom/">
      <img src="/prototipo-hilariom/logo.png?v=2" alt="Hilariom" style="filter: invert(1); opacity: 0.9;" />
    </a>
  </div>
  
  <div class="nav-container">
    {navItems.map((item) => {
      const isActive = currentPath === item.path || (item.path !== '/' && currentPath.startsWith(item.path));
      
      return (
        <a href={item.path} class={`nav-item ${isActive ? 'active' : ''}`}>
          <div class="nav-icon" set:html={item.icon} />
          <span class="nav-label">{item.label}</span>
        </a>
      )
    })}
  </div>
</aside>

<style>
  /* Hidden by default on mobile */
  .sidebar-nav {
    display: none;
  }

  @media (min-width: 768px) {
    .sidebar-nav {
      display: flex;
      flex-direction: column;
      width: 250px;
      height: 100vh;
      background: var(--surface-color, #F7F7F6);
      border-right: 1px solid var(--border-color);
      position: sticky;
      top: 0;
      left: 0;
      overflow-y: auto;
      z-index: 100;
    }

    .sidebar-logo {
      padding: 2.5rem 1.5rem;
      margin-bottom: 1rem;
    }

    .sidebar-logo img {
      width: 150px;
      height: auto;
      display: block;
    }

    .nav-container {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      padding: 0 1rem;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      padding: 1rem 1.25rem;
      border-radius: 8px;
      color: var(--text-muted);
      transition: all 0.2s ease;
      text-decoration: none;
    }

    .nav-item:hover {
      background: rgba(0,0,0,0.03);
      color: var(--text-main);
    }

    .nav-label {
      font-size: 1.05rem;
      font-weight: 700;
    }

    .nav-item.active {
      background: var(--primary-color);
      color: white;
    }
    
    .nav-item.active .nav-icon {
      color: var(--accent-color);
    }
    
    .nav-item.active .nav-label {
      color: white;
    }
  }
</style>
