---import Icon from '../components/Icon.astro';

interface Props {
  title1: string;
  title2: string;
  subtitle: string;
}

const { title1, title2, subtitle } = Astro.props;
---

<div class="header-spacing"></div>

<header class="page-header">
  <div class="header-content">
    <div class="accent-line"></div>
    <h1 class="fade-in-up">{title1} {title2 && <span class="text-yellow">{title2}</span>}</h1>
    <p class="fade-in-up delay-1 text-light">{subtitle}</p>
  </div>
  
  <!-- Abstract structural background -->
  <div class="structural-bg">
    <Icon name="icon_c187d9eb" width="100%" height="100%" />
  </div>
</header>

<style>
  .header-spacing { height: 60px; background: #1a1a1a; }
  
  .page-header {
    position: relative;
    padding: 2.5rem 1.5rem 2rem;
    background-color: #1a1a1a;
    color: white;
    overflow: hidden;
  }
  
  .header-content {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
  }

  .accent-line {
    width: 80px;
    height: 4px;
    background-color: #fce883;
    margin-bottom: 1rem;
  }
  
  .page-header h1 {
    font-size: 2.8rem;
    margin-bottom: 1rem;
    font-weight: 800;
    letter-spacing: -1px;
    text-transform: uppercase;
    color: #ffffff;
  }
  
  @media (min-width: 768px) {
    .page-header h1 {
      font-size: 3rem;
    }
  }

  .text-yellow {
    color: #fce883;
  }

  .text-light { 
    color: #a0a0a0; 
    font-size: 1.15rem;
    max-width: 700px;
    line-height: 1.5;
  }

  .structural-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }
</style>
