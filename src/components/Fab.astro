---import Icon from '../components/Icon.astro';

---

<a href="https://api.whatsapp.com/send?phone=5511989652498&text=Ol%C3%A1!%20Vim%20pelo%20site%20e%20gostaria%20de%20fazer%20um%20or%C3%A7amento" target="_blank" rel="noopener" class="fab hover-scale" aria-label="Fale pelo WhatsApp" onclick="window.trackEvent && window.trackEvent('click_whatsapp', { source: 'fab' })">
  <Icon name="icon_07eda7d0" width="28" height="28" />
</a>

<style>
  .fab {
    position: fixed;
    bottom: calc(var(--nav-height) + 32px); /* Lifted to stay 16px above the floating island */
    right: 16px;
    width: 56px;
    height: 56px;
    background-color: #25D366;
    color: white;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    box-shadow: 0 4px 14px rgba(37, 211, 102, 0.4);
    z-index: 40;
    transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.2s ease;
  }
  
  @media (min-width: 768px) {
    .fab {
      bottom: calc(var(--nav-height) + 40px); /* Lifted to match desktop floating menu position */
      right: 24px;
    }
  }

  .fab:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.5);
  }
  
  .fab:active {
    transform: scale(0.95);
  }
</style>
