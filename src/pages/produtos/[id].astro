---
import Layout from '../../layouts/Layout.astro';
import { produtos } from '../../data/produtos.js';

export function getStaticPaths() {
  return produtos.map((produto) => ({
    params: { id: produto.id },
    props: { produto },
  }));
}

const { produto } = Astro.props;---

<Layout title={`${produto.title} | Hilariom`}>
  <div class="top-nav-bar">
    <a href="/prototipo-hilariom/produtos/" class="back-btn glass-panel hover-scale" id="smart-back-btn">
      <span class="icon">←</span> Voltar
    </a>
  </div>

  <div class="product-header-premium">
    <h1 class="fade-in-up">{produto.title}</h1>
    <p class="fade-in-up delay-1 text-muted">Estrutura técnica pré-fabricada de alta resistência</p>
  </div>

  <div class="product-image-card-premium fade-in-up delay-1">
    <div class="blueprint-bg-premium">
      <img src={produto.img} alt={produto.title} loading="lazy" decoding="async" />
    </div>
  </div>

  <section class="product-details fade-in-up delay-2">
    <div class="content-body">
      <h3>Descrição</h3>
      <p>{produto.desc}</p>
    </div>
    
    <div class="content-body">
      <h3>Dados Técnicos</h3>
      <ul class="tech-list">
        <li><strong>Fck (Resistência):</strong> 40 a 60 MPa</li>
        <li><strong>Seções:</strong> Retangulares, quadradas ou circulares</li>
        <li><strong>Consolos:</strong> Concretados junto com a peça</li>
        <li><strong>Acabamento:</strong> Liso de forma metálica</li>
      </ul>
    </div>

    <div class="content-body">
      <h3>Obras que utilizaram</h3>
      <div class="related-works">
        <a href="/prototipo-hilariom/obras/galpao-logistico-sp/" class="work-card skeleton">
          <img src="https://images.unsplash.com/photo-1587293852726-70cdb56c2866?q=80&w=300&auto=format&fit=crop" alt="Obra 1" loading="lazy" decoding="async" onload="this.parentElement.classList.remove('skeleton')" />
          <div class="work-title glass-panel">Galpão Logístico SP</div>
        </a>
        <a href="/prototipo-hilariom/obras/fabrica-automotiva/" class="work-card skeleton">
          <img src="https://images.unsplash.com/photo-1513694203232-719a280e022f?q=80&w=300&auto=format&fit=crop" alt="Obra 2" loading="lazy" decoding="async" onload="this.parentElement.classList.remove('skeleton')" />
          <div class="work-title glass-panel">Fábrica Automotiva</div>
        </a>
      </div>
    </div>
    
    <div class="cta-container">
      <a href="/prototipo-hilariom/contato/" class="btn btn-primary hover-scale">Solicitar Cotação para esta Peça</a>
    </div>
  </section>

</Layout>

<style>
  .top-nav-bar {
    padding: 1.5rem 1.5rem 0.5rem;
    display: flex;
    justify-content: flex-start;
    max-width: 1100px;
    margin: 0 auto;
  }

  .back-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    color: var(--text-main);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
  }

  .product-header-premium {
    padding: 1rem 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .product-header-premium h1 {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--text-main);
    margin-bottom: 0.25rem;
    letter-spacing: -1px;
    text-transform: uppercase;
  }

  .product-header-premium p {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin: 0;
  }

  .product-image-card-premium {
    padding: 0 1.5rem;
    max-width: 1100px;
    margin: 0 auto 1.5rem;
  }

  .blueprint-bg-premium {
    aspect-ratio: 1.2;
    width: 100%;
    max-height: 400px;
    background-color: #ffffff;
    background-image: radial-gradient(rgba(0, 0, 0, 0.03) 1.5px, transparent 1.5px);
    background-size: 14px 14px;
    border-radius: 20px;
    border: 1px solid rgba(0,0,0,0.06);
    box-shadow: 0 10px 30px rgba(0,0,0,0.02);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    overflow: hidden;
  }

  .blueprint-bg-premium img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 8px 16px rgba(0,0,0,0.04));
  }

  .product-details {
    padding: 1.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .content-body {
    margin-bottom: 2rem;
  }

  .content-body h3 {
    font-size: 1.4rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.5px;
    color: var(--text-main);
    margin-bottom: 1rem;
    border-bottom: 4px solid var(--accent-color);
    display: inline-block;
    padding-bottom: 0.25rem;
  }

  .content-body p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .tech-list {
    list-style: none;
    padding: 0;
  }

  .tech-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border-color);
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  
  .tech-list li:last-child {
    border-bottom: none;
  }

  .tech-list li strong {
    color: var(--text-main);
  }

  .related-works {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    padding-bottom: 1rem;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 0.5rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .related-works::-webkit-scrollbar { display: none; }

  .work-card {
    flex: 0 0 80%;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    position: relative;
    border-radius: var(--border-radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .work-card img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
  }

  .work-title {
    position: absolute;
    bottom: 0.5rem;
    left: 0.5rem;
    right: 0.5rem;
    padding: 0.5rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-main);
    text-align: center;
  }
  
  .cta-container {
    margin-top: 1rem;
  }

  .btn-primary {
    display: block;
    width: 100%;
    text-align: center;
    background: var(--accent-color);
    color: var(--primary-color);
    padding: 1rem;
    border-radius: 8px;
    font-weight: 700;
    box-shadow: var(--shadow-sm);
  }

  /* Utilities */
  .fade-in-up {
    animation: fadeInUp 0.5s ease forwards;
    opacity: 0;
    transform: translateY(15px);
  }
  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.2s; }

  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const backBtn = document.getElementById('smart-back-btn');
    if (backBtn) {
      backBtn.addEventListener('click', (e) => {
        e.preventDefault();
        if (window.history.length > 1) {
          window.history.back();
        } else {
          window.location.href = '/prototipo-hilariom/produtos/';
        }
      });
    }
  });
</script>



