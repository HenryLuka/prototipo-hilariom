---
import Layout from '../../layouts/Layout.astro';




---

<Layout title="Detalhe da Obra">
  <div class="obra-hero">
    <div class="hero-overlay"></div>
    <img src="https://images.unsplash.com/photo-1587293852726-70cdb56c2866?q=80&w=800&auto=format&fit=crop" alt="Obra Hero" class="hero-bg" />
    
    <!-- Top Nav Actions (Back button) -->
    <div class="top-actions">
      <a href="/prototipo-hilariom/obras/" class="back-btn glass-panel hover-scale" id="smart-back-btn">
        <span class="icon">←</span> Voltar
      </a>
    </div>

    <div class="hero-content">
      <span class="badge">Logística</span>
      <h1 class="fade-in-up">Galpão Logístico SP</h1>
      <p class="fade-in-up delay-1 text-muted-light"><span class="icon" style="vertical-align: middle; margin-right: 4px;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></span>Guarulhos, SP</p>
    </div>
  </div>

  <section class="obra-details fade-in-up delay-2">
    <div class="data-grid glass-panel">
      <div class="data-item">
        <span class="data-label">Volume de Concreto</span>
        <span class="data-value">1.250 m³</span>
      </div>
      <div class="data-item">
        <span class="data-label">Prazo de Execução</span>
        <span class="data-value">45 dias</span>
      </div>
      <div class="data-item">
        <span class="data-label">Área Construída</span>
        <span class="data-value">15.000 m²</span>
      </div>
    </div>

    <div class="content-body">
      <h3>Sobre o Projeto</h3>
      <p>Projeto de centro logístico de alto padrão, desenvolvido com estrutura totalmente pré-fabricada para garantir velocidade e robustez. Os vãos de 25 metros foram vencidos com vigas protendidas de alta resistência.</p>
    </div>
    
    <div class="content-body">
      <h3>Peças Utilizadas nesta Obra</h3>
      <p class="pecas-desc">Clique para conhecer cada componente em detalhe.</p>
      <div class="scroll-container">
        <button class="scroll-btn left" aria-label="Rolar para esquerda"><svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
        <div class="pecas-list scroll-area">
          <a href="/prototipo-hilariom/produtos/pilares" class="peca-visual hover-scale">
            <div class="peca-thumb skeleton">
              <img src="https://www.galleon.com.br/wp-content/uploads/2015/12/06.png" alt="Pilares" loading="lazy" decoding="async" onload="this.parentElement.classList.remove('skeleton')" />
            </div>
            <span>Pilares</span>
          </a>
          <a href="/prototipo-hilariom/produtos/vigas-cobertura" class="peca-visual hover-scale">
            <div class="peca-thumb skeleton">
              <img src="https://www.galleon.com.br/wp-content/uploads/2015/12/08.png" alt="Vigas de Cobertura" loading="lazy" decoding="async" onload="this.parentElement.classList.remove('skeleton')" />
            </div>
            <span>Vigas de Cobertura</span>
          </a>
          <a href="/prototipo-hilariom/produtos/paineis" class="peca-visual hover-scale">
            <div class="peca-thumb skeleton">
              <img src="https://www.galleon.com.br/wp-content/uploads/2015/12/05.png" alt="Painéis de Fechamento" loading="lazy" decoding="async" onload="this.parentElement.classList.remove('skeleton')" />
            </div>
            <span>Painéis de Fechamento</span>
          </a>
        </div>
        <button class="scroll-btn right" aria-label="Rolar para direita"><svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><polyline points="9 18 15 12 9 6"></polyline></svg></button>
      </div>
    </div>

    <div class="content-body">
      <h3>Galeria da Obra</h3>
      <div class="gallery-grid">
        <img src="https://images.unsplash.com/photo-1541888079011-309df51ab0c6?q=80&w=300&auto=format&fit=crop" class="gallery-img skeleton" alt="Foto 1" loading="lazy" decoding="async" onload="this.classList.remove('skeleton')" />
        <img src="https://images.unsplash.com/photo-1518640035171-897db674d812?q=80&w=300&auto=format&fit=crop" class="gallery-img skeleton" alt="Foto 2" loading="lazy" decoding="async" onload="this.classList.remove('skeleton')" />
      </div>
    </div>
  </section>

  <!-- Gallery Modal -->
  <div id="gallery-modal" class="modal-backdrop">
    <div class="modal-content">
      <button class="close-modal" id="close-modal">&times;</button>
      <img id="modal-img" src="" alt="Foto expandida" />
    </div>
  </div>

</Layout>

<style>
  .obra-hero {
    position: relative;
    height: 50vh;
    min-height: 350px;
    display: flex;
    align-items: flex-end;
  }

  .hero-bg {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .hero-overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(to bottom, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.8) 100%);
    z-index: 2;
  }

  .top-actions {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 10;
  }

  .back-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    color: var(--text-main);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    padding: 2rem 1.5rem;
    color: white;
    width: 100%;
  }

  .badge {
    background: var(--primary-color);
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    display: inline-block;
  }

  .hero-content h1 {
    font-size: 2rem;
    margin-bottom: 0.25rem;
  }

  .text-muted-light {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9rem;
  }

  .obra-details {
    padding: 1.5rem;
    margin-top: -30px;
    position: relative;
    z-index: 5;
  }

  .data-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    padding: 1.25rem;
    border-radius: var(--border-radius);
    text-align: center;
    margin-bottom: 2rem;
  }

  .data-item {
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--border-color);
  }

  .data-item:last-child {
    border-right: none;
  }

  .data-label {
    font-size: 0.65rem;
    color: var(--text-muted);
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .data-value {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--primary-color);
  }

  .content-body {
    margin-bottom: 2rem;
  }

  .content-body h3 {
    font-size: 1.4rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.5px;
    color: var(--text-main);
    margin-bottom: 1rem;
    border-bottom: 4px solid var(--accent-color);
    display: inline-block;
    padding-bottom: 0.25rem;
  }

  .content-body p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .pecas-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .pecas-list {
    display: flex;
    overflow-x: auto;
    gap: 0.75rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 0.5rem;
  }
  .pecas-list::-webkit-scrollbar { display: none; }

  .peca-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 100px;
    text-decoration: none;
    flex-shrink: 0;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  .peca-thumb {
    width: 100px;
    height: 100px;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 0.4rem;
    box-shadow: var(--shadow-sm);
    border: 2px solid var(--accent-color);
  }

  .peca-thumb img {
    width: 100%; height: 100%;
    object-fit: cover;
  }

  .peca-visual span {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-main);
    text-align: center;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .gallery-img {
    width: 100%;
    aspect-ratio: 1/1;
    object-fit: cover;
    border-radius: 8px;
    box-shadow: var(--shadow-sm);
  }

  

  /* Scroll Containers */
  .scroll-container {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .scroll-container::before,
  .scroll-container::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 40px;
    pointer-events: none;
    z-index: 5;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .scroll-container::before {
    left: 0;
    background: linear-gradient(to right, var(--bg-color, white) 20%, transparent);
  }

  .scroll-container::after {
    right: 0;
    background: linear-gradient(to left, var(--bg-color, white) 20%, transparent);
  }

  .scroll-container.can-scroll-left::before { opacity: 1; }
  .scroll-container.can-scroll-right::after { opacity: 1; }

  .scroll-btn {
    position: absolute;
    z-index: 10;
    top: 50%;
    transform: translateY(-50%);
    background: white;
    border: 1px solid var(--border-color);
    border-radius: 50%;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    cursor: pointer;
    color: var(--primary-color);
    transition: opacity 0.2s, background 0.2s;
    opacity: 0;
    pointer-events: none;
  }

  .scroll-btn.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .scroll-btn:active {
    background: #f0f0f0;
  }

  .scroll-btn.left { left: -10px; }
  .scroll-btn.right { right: -10px; }

  /* Modal Styles */
  .modal-backdrop {
    position: fixed;
    top: 0; left: 0; width: 100vw; height: 100vh;
    background: rgba(0, 0, 0, 0.9);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .modal-backdrop.active {
    opacity: 1;
    pointer-events: auto;
  }
  .modal-content {
    position: relative;
    max-width: 90vw;
    max-height: 90vh;
  }
  .modal-content img {
    max-width: 100%;
    max-height: 90vh;
    border-radius: 8px;
    object-fit: contain;
  }
  .close-modal {
    position: absolute;
    top: -40px;
    right: 0;
    background: none;
    border: none;
    color: white;
    font-size: 2.5rem;
    line-height: 1;
    cursor: pointer;
    padding: 0 10px;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    // Gallery Modal Logic
    const galleryImgs = document.querySelectorAll('.gallery-img');
    const modal = document.getElementById('gallery-modal');
    const modalImg = document.getElementById('modal-img') as HTMLImageElement;
    const closeModal = document.getElementById('close-modal');

    galleryImgs.forEach(img => {
      img.addEventListener('click', () => {
        if (modal && modalImg && img instanceof HTMLImageElement) {
          modalImg.src = img.src;
          modal.classList.add('active');
        }
      });
    });

    if (closeModal && modal) {
      closeModal.addEventListener('click', () => {
        modal.classList.remove('active');
      });
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          modal.classList.remove('active');
        }
      });
    }

    // Scroll Buttons Logic
    const containers = document.querySelectorAll('.scroll-container');
    
    containers.forEach(container => {
      const scrollArea = container.querySelector('.scroll-area');
      const leftBtn = container.querySelector('.scroll-btn.left');
      const rightBtn = container.querySelector('.scroll-btn.right');
      
      if (!scrollArea || !leftBtn || !rightBtn) return;

      const updateButtons = () => {
        const { scrollLeft, scrollWidth, clientWidth } = scrollArea;
        if (scrollLeft > 5) {
          leftBtn.classList.add('visible');
          container.classList.add('can-scroll-left');
        } else {
          leftBtn.classList.remove('visible');
          container.classList.remove('can-scroll-left');
        }
        
        if (scrollLeft + clientWidth < scrollWidth - 5) {
          rightBtn.classList.add('visible');
          container.classList.add('can-scroll-right');
        } else {
          rightBtn.classList.remove('visible');
          container.classList.remove('can-scroll-right');
        }
      };

      scrollArea.addEventListener('scroll', updateButtons, { passive: true });
      window.addEventListener('resize', updateButtons, { passive: true });
      setTimeout(updateButtons, 100);

      leftBtn.addEventListener('click', () => {
        const firstCard = scrollArea.children[0] as HTMLElement;
        const gap = parseFloat(getComputedStyle(scrollArea).gap) || 12;
        const step = (firstCard ? firstCard.offsetWidth + gap : 150) + 20;
        scrollArea.scrollBy({ left: -step, behavior: 'smooth' });
      });
      rightBtn.addEventListener('click', () => {
        const firstCard = scrollArea.children[0] as HTMLElement;
        const gap = parseFloat(getComputedStyle(scrollArea).gap) || 12;
        const step = (firstCard ? firstCard.offsetWidth + gap : 150) + 20;
        scrollArea.scrollBy({ left: step, behavior: 'smooth' });
      });
    });

    // Smart Back Button
    const backBtn = document.getElementById('smart-back-btn');
    if (backBtn) {
      backBtn.addEventListener('click', (e) => {
        e.preventDefault();
        if (window.history.length > 1) {
          window.history.back();
        } else {
          window.location.href = '/prototipo-hilariom/obras/';
        }
      });
    }
  });
</script>

<script is:inline>
  // Dispatch view_obra event when page loads
  document.addEventListener('astro:page-load', () => {
    if (window['trackEvent']) {
      window['trackEvent']('view_obra', { obra_name: 'Galpão Logístico SP' });
    }
  }, { once: true });
</script>



