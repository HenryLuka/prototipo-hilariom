---
import Layout from '../../layouts/Layout.astro';
import { obras } from '../../data/obras.js';

export function getStaticPaths() {
  return obras.map((obra) => ({
    params: { id: obra.id },
    props: { obra },
  }));
}

const { obra } = Astro.props;
---

<Layout title={`${obra.title} | Hilariom`}>
  <div class="obra-hero">
    <div class="hero-overlay"></div>
    <img src={obra.img} alt={obra.title} class="hero-bg" />
    
    <!-- Top Nav Actions (Back button) -->
    <div class="top-actions">
      <a href="/prototipo-hilariom/obras/" class="back-btn glass-panel hover-scale" id="smart-back-btn">
        <span class="icon">←</span> Voltar
      </a>
    </div>

    <div class="hero-content">
      <span class="badge">{obra.segment}</span>
      <h1 class="fade-in-up">{obra.title}</h1>
      <p class="fade-in-up delay-1 text-muted-light"><span class="icon" style="vertical-align: middle; margin-right: 4px;"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg></span>{obra.local}</p>
    </div>
  </div>

  <section class="obra-details fade-in-up delay-2">
    <div class="data-grid glass-panel">
      <div class="data-item">
        <span class="data-label">Volume de Concreto</span>
        <span class="data-value">{obra.volume}</span>
      </div>
      <div class="data-item">
        <span class="data-label">Prazo de Execução</span>
        <span class="data-value">{obra.prazo}</span>
      </div>
      <div class="data-item">
        <span class="data-label">Área Construída</span>
        <span class="data-value">{obra.area}</span>
      </div>
    </div>

    <div class="content-body">
      <h3>Sobre o Projeto</h3>
      <p>{obra.desc}</p>
    </div>
    
    <div class="content-body">
      <h3>Peças Utilizadas nesta Obra</h3>
      <p class="pecas-desc">Clique para conhecer cada componente em detalhe.</p>
      <div class="scroll-container">
        <button class="scroll-btn left" aria-label="Rolar para esquerda"><svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><polyline points="15 18 9 12 15 6"></polyline></svg></button>
        <div class="pecas-list scroll-area">
          {obra.pecas.map((peca) => (
            <a href={`/prototipo-hilariom/produtos/${peca.id}/`} class="peca-visual hover-scale">
              <div class="peca-thumb skeleton">
                <img src={peca.img} alt={peca.title} loading="lazy" decoding="async" onload="this.parentElement.classList.remove('skeleton')" />
              </div>
              <span>{peca.title}</span>
            </a>
          ))}
        </div>
        <button class="scroll-btn right" aria-label="Rolar para direita"><svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><polyline points="9 18 15 12 9 6"></polyline></svg></button>
      </div>
    </div>

    <div class="content-body">
      <h3>Galeria da Obra</h3>
      <div class="gallery-grid">
        {obra.gallery.map((photo, idx) => (
          <img src={photo} class="gallery-img skeleton" alt={`Foto ${idx + 1}`} loading="lazy" decoding="async" onload="this.classList.remove('skeleton')" />
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .obra-hero {
    position: relative;
    height: 50vh;
    min-height: 350px;
    display: flex;
    align-items: flex-end;
  }

  .hero-bg {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .hero-overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(to bottom, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.8) 100%);
    z-index: 2;
  }

  .top-actions {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 10;
  }

  .back-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    color: var(--text-main);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    padding: 2rem 1.5rem;
    color: white;
    width: 100%;
  }

  .badge {
    background: var(--primary-color);
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    display: inline-block;
  }

  .hero-content h1 {
    font-size: 2rem;
    margin-bottom: 0.25rem;
  }

  .text-muted-light {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
  }

  .obra-details {
    padding: 1.5rem;
  }

  .data-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    padding: 1rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .data-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .data-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
    font-weight: 600;
  }

  .data-value {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-main);
  }

  .content-body {
    margin-bottom: 2.5rem;
  }

  .content-body h3 {
    font-size: 1.25rem;
    color: var(--text-main);
    margin-bottom: 0.75rem;
    position: relative;
    padding-bottom: 0.5rem;
  }

  .content-body h3::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 3px;
    background: var(--accent-color);
  }

  .content-body p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .pecas-desc {
    margin-bottom: 1rem !important;
  }

  .pecas-list {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    padding-bottom: 0.75rem;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 0.5rem;
  }

  .pecas-list::-webkit-scrollbar {
    display: none;
  }

  .peca-visual {
    flex: 0 0 auto;
    width: 100px;
    text-align: center;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-main);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  .peca-thumb {
    width: 100px;
    height: 100px;
    border-radius: var(--border-radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .peca-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .gallery-img {
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: var(--border-radius);
    object-fit: cover;
    box-shadow: var(--shadow-sm);
  }

  /* Scroll Controllers styling */
  .scroll-container {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .scroll-container::before,
  .scroll-container::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 30px;
    pointer-events: none;
    z-index: 5;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .scroll-container::before {
    left: 0;
    background: linear-gradient(to right, var(--bg-color, white) 20%, transparent);
  }

  .scroll-container::after {
    right: 0;
    background: linear-gradient(to left, var(--bg-color, white) 20%, transparent);
  }

  .scroll-container.can-scroll-left::before { opacity: 1; }
  .scroll-container.can-scroll-right::after { opacity: 1; }

  .scroll-btn {
    position: absolute;
    z-index: 10;
    top: 50%;
    transform: translateY(-50%);
    background: white;
    border: 1px solid var(--border-color);
    border-radius: 50%;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    cursor: pointer;
    color: var(--primary-color);
    transition: opacity 0.2s, background 0.2s;
    opacity: 0;
    pointer-events: none;
  }

  .scroll-btn.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .scroll-btn.left { left: 4px; }
  .scroll-btn.right { right: 4px; }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const containers = document.querySelectorAll('.scroll-container');
    
    containers.forEach(container => {
      const scrollArea = container.querySelector('.scroll-area');
      const leftBtn = container.querySelector('.scroll-btn.left');
      const rightBtn = container.querySelector('.scroll-btn.right');
      
      if (!scrollArea || !leftBtn || !rightBtn) return;

      const updateButtons = () => {
        const { scrollLeft, scrollWidth, clientWidth } = scrollArea;
        if (scrollLeft > 5) {
          leftBtn.classList.add('visible');
          container.classList.add('can-scroll-left');
        } else {
          leftBtn.classList.remove('visible');
          container.classList.remove('can-scroll-left');
        }
        
        if (scrollLeft + clientWidth < scrollWidth - 5) {
          rightBtn.classList.add('visible');
          container.classList.add('can-scroll-right');
        } else {
          rightBtn.classList.remove('visible');
          container.classList.remove('can-scroll-right');
        }
      };

      scrollArea.addEventListener('scroll', updateButtons, { passive: true });
      window.addEventListener('resize', updateButtons, { passive: true });
      setTimeout(updateButtons, 100);

      leftBtn.addEventListener('click', () => {
        const firstCard = scrollArea.children[0];
        const gap = parseFloat(getComputedStyle(scrollArea).gap) || 16;
        const step = firstCard ? firstCard.offsetWidth + gap : 100;
        scrollArea.scrollBy({ left: -step, behavior: 'smooth' });
      });
      rightBtn.addEventListener('click', () => {
        const firstCard = scrollArea.children[0];
        const gap = parseFloat(getComputedStyle(scrollArea).gap) || 16;
        const step = firstCard ? firstCard.offsetWidth + gap : 100;
        scrollArea.scrollBy({ left: step, behavior: 'smooth' });
      });
    });

    const backBtn = document.getElementById('smart-back-btn');
    if (backBtn) {
      backBtn.addEventListener('click', (e) => {
        e.preventDefault();
        if (window.history.length > 1) {
          window.history.back();
        } else {
          window.location.href = '/prototipo-hilariom/obras/';
        }
      });
    }
  });
</script>
