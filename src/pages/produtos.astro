---
import Layout from '../layouts/Layout.astro';
import { produtos } from '../data/produtos.js';
---

<Layout title="Produtos e Peças">
  <div class="header-spacing"></div>
  
  <header class="page-header">
    <div class="header-content">
      <div class="accent-line"></div>
      <h1 class="fade-in-up">Catálogo <span class="text-yellow">Técnico</span></h1>
      <p class="fade-in-up delay-1 text-light">Peças em concreto pré-fabricado projetadas para máxima resistência e durabilidade em estruturas industriais, comerciais e logísticas.</p>
    </div>
    
    <!-- Abstract structural background -->
    <div class="structural-bg">
      <svg width="100%" height="100%" viewBox="0 0 400 200" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,200 L100,100 L150,200 Z" fill="rgba(252, 232, 131, 0.05)" />
        <path d="M200,200 L300,50 L400,200 Z" fill="rgba(252, 232, 131, 0.03)" />
        <line x1="50" y1="0" x2="50" y2="200" stroke="rgba(252, 232, 131, 0.1)" stroke-width="2" />
        <line x1="250" y1="0" x2="250" y2="200" stroke="rgba(252, 232, 131, 0.1)" stroke-width="2" />
        <line x1="0" y1="150" x2="400" y2="150" stroke="rgba(252, 232, 131, 0.1)" stroke-width="2" />
      </svg>
    </div>
  </header>

  <section class="products-container">
    <div class="products-grid">
      {produtos.map((p, index) => (
        <a href={`/prototipo-hilariom/produtos/${p.id}/`} class={`product-card fade-in-up delay-${(index % 3) + 1}`}>
          <div class="card-accent"></div>
          <div class="img-wrapper skeleton">
            <img src={p.img} alt={p.title} loading="lazy" decoding="async" onload="this.parentElement.classList.remove('skeleton')" />
            <div class="img-overlay">
              <span class="icon-plus">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              </span>
            </div>
          </div>
          <div class="product-info">
            <div class="product-header">
              <h3>{p.title}</h3>
              <div class="structural-dot"></div>
            </div>
            <p class="text-muted">{p.desc}</p>
            <div class="product-footer">
              <span class="view-more">Ver Ficha Técnica</span>
              <svg class="arrow-icon" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

</Layout>

<style>
  .header-spacing { height: 60px; background: #1a1a1a; }
  
  .page-header {
    position: relative;
    padding: 2.5rem 1.5rem 2rem;
    background-color: #1a1a1a; /* Dark premium background */
    color: white;
    overflow: hidden;
  }
  
  .header-content {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
  }

  .accent-line {
    width: 80px;
    height: 4px;
    background-color: #fce883; /* Hilariom yellow */
    margin-bottom: 1rem;
  }
  
  .page-header h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
    font-weight: 800;
    letter-spacing: -1px;
    text-transform: uppercase;
    color: #ffffff; /* Explicitly set to white so "Catálogo" is visible */
  }

  .text-yellow {
    color: #fce883;
  }

  .text-light { 
    color: #a0a0a0; 
    font-size: 1.15rem;
    max-width: 700px;
    line-height: 1.6;
  }

  .structural-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  .products-container {
    background-color: #f8f9fa;
    padding: 4rem 1.5rem 6rem;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 5px 25px rgba(0,0,0,0.05);
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    position: relative;
    text-decoration: none;
    border: 1px solid rgba(0,0,0,0.03);
  }

  .card-accent {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background-color: #fce883;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
    z-index: 10;
  }

  .product-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 35px rgba(0,0,0,0.1);
  }

  .product-card:hover .card-accent {
    transform: scaleX(1);
  }

  .img-wrapper {
    position: relative;
    height: 240px;
    overflow: hidden;
    background-color: #f9f9fb;
    background-image: 
      linear-gradient(rgba(0, 0, 0, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.03) 1px, transparent 1px),
      linear-gradient(rgba(252, 232, 131, 0.15) 1px, transparent 1px),
      linear-gradient(90deg, rgba(252, 232, 131, 0.15) 1px, transparent 1px);
    background-size: 10px 10px, 10px 10px, 50px 50px, 50px 50px;
    padding: 1.5rem; /* Add padding so drawings don't touch edges */
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }

  .img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: contain; /* Prevents the images from being cropped */
    transition: transform 0.6s ease;
  }

  .product-card:hover .img-wrapper img {
    transform: scale(1.08);
  }

  .img-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(26, 26, 26, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .product-card:hover .img-overlay {
    opacity: 1;
  }

  .icon-plus {
    width: 56px;
    height: 56px;
    background-color: #fce883;
    color: #1a1a1a;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: scale(0.5);
    transition: transform 0.4s ease cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .product-card:hover .icon-plus {
    transform: scale(1);
  }

  .product-info {
    padding: 1.8rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .product-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.8rem;
  }

  .product-header h3 {
    font-size: 1.35rem;
    color: #1a1a1a;
    margin: 0;
    font-weight: 700;
    padding-right: 15px;
    line-height: 1.3;
  }

  .structural-dot {
    flex-shrink: 0;
    width: 10px;
    height: 10px;
    background-color: #fce883;
    border-radius: 2px;
    margin-top: 6px;
  }

  .product-info p {
    font-size: 0.95rem;
    color: #666;
    margin-bottom: 2rem;
    line-height: 1.6;
    flex: 1;
  }

  .product-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid #eaeaea;
    padding-top: 1.2rem;
    color: #333;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: color 0.3s ease;
  }

  .arrow-icon {
    transition: transform 0.3s ease;
    color: #fce883; /* Always yellow */
  }

  .product-card:hover .product-footer {
    color: #1a1a1a;
  }

  .product-card:hover .arrow-icon {
    transform: translateX(5px);
  }

  /* Utilities */
  .fade-in-up {
    animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
    transform: translateY(20px);
  }
  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.2s; }
  .delay-3 { animation-delay: 0.3s; }

  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Responsive grid adjustments */
  @media (max-width: 768px) {
    .page-header h1 { font-size: 2.2rem; }
    .products-grid { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>
