---import Icon from '../components/Icon.astro';

import Layout from '../layouts/Layout.astro';
---

<Layout title="Trabalhe Conosco | Hilariom">
  <!-- Top Nav Actions (Back button) -->
  <div class="top-actions fade-in-up">
    <a href="/prototipo-hilariom/" class="back-btn glass-panel hover-scale">
      <span class="icon">←</span> Voltar
    </a>
  </div>

  <header class="page-header-premium fade-in-up delay-1">
    <div class="badge-accent">CARREIRAS</div>
    <h1>Construa sua história <strong>junto com a gente</strong></h1>
    <p class="text-muted-premium">A Hilariom está em constante crescimento e busca profissionais talentosos para fazer parte da nossa história de sucesso na construção civil. Se você é apaixonado por grandes obras, venha para o nosso time!</p>
  </header>

  <section class="careers-section fade-in-up delay-2">
    <form class="resume-form-premium hover-scale">
      <div class="form-header">
        <div class="form-icon">
          <Icon name="icon_4235cb53" width="24" height="24" />
        </div>
        <h3 class="form-title">Envie seu Currículo</h3>
      </div>
      
      <div class="form-grid">
        <div class="form-group">
          <label for="name">Nome completo</label>
          <input type="text" id="name" placeholder="Ex: Maria Silva" required />
        </div>
        
        <div class="form-group">
          <label for="email">E-mail</label>
          <input type="email" id="email" placeholder="maria@email.com" required />
        </div>
        
        <div class="form-group full-width">
          <label for="area">Área de Interesse</label>
          <div class="select-wrapper">
            <select id="area" required>
              <option value="" disabled selected>Selecione uma área</option>
              <option value="engenharia">Engenharia</option>
              <option value="producao">Produção / Fábrica</option>
              <option value="comercial">Comercial</option>
              <option value="administrativo">Administrativo</option>
            </select>
          </div>
        </div>

        <div class="form-group full-width">
          <label for="resume">Anexar Currículo (PDF)</label>
          <div class="file-upload-premium">
            <input type="file" id="resume" accept=".pdf" required />
            <div class="upload-btn-content">
              <Icon name="icon_9858aa5a" width="24" height="24" />
              <span>Clique aqui para selecionar seu currículo</span>
            </div>
          </div>
        </div>
      </div>

      <button type="button" class="btn-primary hover-scale mt-4" onclick="alert('Currículo enviado com sucesso! (Simulação)')">Enviar Currículo</button>
    </form>
  </section>

</Layout>

<style>
  /* ===== NAVIGATION ===== */
  .top-actions {
    padding: 1.5rem 1.5rem 0.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    border-radius: 20px;
    color: var(--text-main);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    background: #ffffff;
    box-shadow: var(--shadow-sm);
  }

  /* ===== HEADER ===== */
  .page-header-premium {
    padding: 1.5rem 1.5rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .badge-accent {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #bfa519;
    background: rgba(252, 232, 131, 0.3);
    padding: 0.35rem 0.8rem;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .page-header-premium h1 {
    font-size: 2rem;
    font-weight: 400;
    color: var(--text-muted);
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .page-header-premium h1 strong {
    font-weight: 900;
    color: var(--text-main);
    display: block;
  }

  .text-muted-premium {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* ===== FORM SECTION ===== */
  .careers-section {
    padding: 0 1.5rem 5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .resume-form-premium {
    background: #ffffff;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 15px 35px rgba(0,0,0,0.04);
    border: 1px solid rgba(0,0,0,0.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .resume-form-premium:hover {
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
  }

  .form-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .form-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(252, 232, 131, 0.2);
    color: #a89115;
    border-radius: 12px;
    flex-shrink: 0;
  }

  .form-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text-main);
    margin: 0;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 768px) {
    .form-grid {
      grid-template-columns: 1fr 1fr;
    }
    .full-width {
      grid-column: 1 / -1;
    }
  }

  .form-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--text-main);
  }

  .form-group input, .form-group select {
    width: 100%;
    padding: 0.9rem 1rem;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 8px;
    font-family: inherit;
    font-size: 0.95rem;
    background: #fdfdfd;
    transition: all 0.2s;
    color: var(--text-main);
  }

  .form-group input:focus, .form-group select:focus {
    outline: none;
    border-color: #fce883;
    box-shadow: 0 0 0 3px rgba(252, 232, 131, 0.2);
    background: #fff;
  }

  .file-upload-premium {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px dashed rgba(0,0,0,0.15);
    background: #fafafa;
    border-radius: 8px;
    padding: 2rem;
    text-align: center;
    transition: all 0.2s;
    cursor: pointer;
  }

  .file-upload-premium:hover {
    border-color: #bfa519;
    background: rgba(252, 232, 131, 0.05);
  }

  .file-upload-premium input[type=file] {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    opacity: 0;
    cursor: pointer;
  }

  .upload-btn-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-muted);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .upload-btn-content svg {
    color: #a89115;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #1a1a1a;
    color: #ffffff;
    padding: 1rem 2rem;
    border-radius: 8px;
    font-weight: 700;
    text-decoration: none;
    width: 100%;
    border: none;
    font-size: 1rem;
    cursor: pointer;
  }
  .mt-4 {
    margin-top: 1.5rem;
  }

  
</style>




