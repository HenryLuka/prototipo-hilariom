---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<Layout title="Raio de Atuação">
  <PageHeader 
    title1="Raio de" 
    title2="Atuação" 
    subtitle="Chegamos onde sua obra precisa."
  />

  <section class="map-section fade-in-up delay-2">
    <div class="map-container glass-panel">
      <!-- Simulated visual map -->
      <div class="map-placeholder">
        <div class="factory-point">
          <span class="pulse"></span>
          <span class="icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m2 22 8-8v8"/><path d="M10 14V2a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v20"/><path d="m2 22 20 0"/><path d="M16 10h-2"/><path d="M16 14h-2"/><path d="M16 6h-2"/></svg></span>
        </div>
        <div class="radius-circle"></div>
      </div>
    </div>
    
    <div class="info-card">
      <h3>Sediada em SP</h3>
      <p class="text-muted">Nossa fábrica localizada estrategicamente permite atendimento eficiente num raio de até 500km.</p>
      <ul class="states-list">
        <li><span class="check">✓</span> São Paulo</li>
        <li><span class="check">✓</span> Rio de Janeiro</li>
        <li><span class="check">✓</span> Minas Gerais (Sul)</li>
        <li><span class="check">✓</span> Paraná (Norte)</li>
      </ul>
    </div>
  </section>

</Layout>

<style>

  .text-muted { color: var(--text-muted); }

  .map-section {
    padding: 1rem 1.5rem 3rem;
  }

  .map-container {
    height: 300px;
    border-radius: var(--border-radius-lg);
    background: #e0e7ff;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .map-placeholder {
    position: relative;
    width: 100%;
    height: 100%;
    /* Abstract map pattern */
    background-image: radial-gradient(#c7d2fe 2px, transparent 2px);
    background-size: 20px 20px;
  }

  .factory-point {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
  }
  
  .factory-point .icon {
    font-size: 1.5rem;
    position: relative;
    z-index: 2;
  }

  .pulse {
    position: absolute;
    width: 100%;
    height: 100%;
    background: var(--primary-color);
    border-radius: 50%;
    z-index: 1;
    animation: pulse 2s infinite;
    opacity: 0.6;
  }

  .radius-circle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 250px;
    height: 250px;
    border: 2px dashed var(--primary-color);
    border-radius: 50%;
    background: rgba(52, 52, 50, 0.05);
  }

  .info-card {
    background: var(--surface-color);
    padding: 1.5rem;
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-md);
  }

  .info-card h3 {
    margin-bottom: 0.5rem;
    color: var(--text-main);
  }
  
  .info-card p {
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .states-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .states-list li {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-main);
  }

  .check {
    color: var(--accent-color);
    font-weight: bold;
    margin-right: 0.25rem;
  }

  
  
  @keyframes pulse {
    0% { transform: scale(1); opacity: 0.6; }
    70% { transform: scale(2); opacity: 0; }
    100% { transform: scale(1); opacity: 0; }
  }
</style>



