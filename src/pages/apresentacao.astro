---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Apresentação Comercial">
  <div class="apresentacao-wrapper">
    <div class="apresentacao-container">
      
      <!-- Lado Esquerdo: Conteúdo e Ações -->
      <div class="content-side fade-in-up">
        <div class="badge">Material Exclusivo</div>
        <h1>Apresentação Institucional</h1>
        <p class="subtitle">Conheça a fundo o padrão de qualidade Hilariom. Baixe nosso portfólio completo para compartilhar com sua equipe.</p>
        
        <div class="features-list">
          <div class="feature-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>Catálogo completo de soluções pré-fabricadas</span>
          </div>
          <div class="feature-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>Galeria com nossas maiores obras entregues</span>
          </div>
          <div class="feature-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>Detalhes sobre nossa capacidade fabril</span>
          </div>
        </div>

        <div class="actions">
          <a href="/prototipo-hilariom/apresentacao-Hilariom.pdf" download class="btn btn-download hover-scale" onclick="window.trackEvent && window.trackEvent('download_pdf', { source: 'apresentacao' })">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Baixar PDF (5.2 MB)
          </a>
          
          <a href="https://wa.me/?text=Confira%20a%20apresentação%20comercial%20da%20Hilariom:%20https://Hilariom.com.br/apresentacao" target="_blank" rel="noopener" class="btn btn-whatsapp hover-scale">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
            Compartilhar via WhatsApp
          </a>
        </div>
      </div>

      <!-- Lado Direito: Preview do PDF -->
      <div class="preview-side fade-in-up delay-1">
        <div class="pdf-card">
          <div class="pdf-image-wrapper">
            <!-- Capa simulada com CSS e background -->
            <div class="pdf-cover" style="background-image: url('https://images.unsplash.com/photo-1542744173-8e7e53415bb0?q=80&w=600&auto=format&fit=crop');">
              <div class="pdf-overlay"></div>
              <div class="pdf-logo">Hilariom.</div>
              <div class="pdf-title">APRESENTAÇÃO<br/>COMERCIAL 2026</div>
            </div>
          </div>
          <div class="pdf-info">
            <div class="pdf-format">PDF Document</div>
            <div class="pdf-pages">12 Páginas</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</Layout>

<style>
  .apresentacao-wrapper {
    padding: 3rem 1.5rem 5rem;
    min-height: calc(100vh - 80px); /* Fill screen minus header/nav */
    display: flex;
    align-items: center;
    background: #f8f9fa; /* Soft background */
  }

  .apresentacao-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    width: 100%;
  }

  @media (min-width: 992px) {
    .apresentacao-container {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }
  }

  /* Left Side Content */
  .badge {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgba(252, 232, 131, 0.2);
    color: #bfa100;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 1px;
    text-transform: uppercase;
    border-radius: 50px;
    margin-bottom: 1.5rem;
  }

  .content-side h1 {
    font-size: 2.2rem;
    color: var(--text-main);
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  @media (min-width: 768px) {
    .content-side h1 {
      font-size: 3.5rem;
    }
  }

  .subtitle {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 2.5rem;
    max-width: 500px;
  }

  .features-list {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    margin-bottom: 3rem;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .feature-item svg {
    color: #10b981; /* Success green */
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .feature-item span {
    font-size: 1rem;
    color: var(--text-main);
    font-weight: 500;
  }

  /* Actions */
  .actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .actions {
      flex-direction: row;
    }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-download {
    background: var(--primary-color);
    color: white;
    box-shadow: 0 4px 12px rgba(52, 52, 50, 0.2);
  }

  .btn-download:hover {
    background: #1a1a1a;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(52, 52, 50, 0.3);
  }

  .btn-whatsapp {
    background: white;
    color: var(--text-main);
    border: 1px solid rgba(0,0,0,0.1);
  }

  .btn-whatsapp:hover {
    border-color: #25D366;
    color: #25D366;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(37, 211, 102, 0.15);
  }
  
  .btn-whatsapp svg {
    color: #25D366;
  }

  /* Right Side Preview */
  .preview-side {
    display: flex;
    justify-content: center;
    align-items: center;
    perspective: 1000px;
  }

  .pdf-card {
    width: 100%;
    max-width: 380px;
    background: white;
    border-radius: 12px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    transform: rotateY(-5deg) rotateX(5deg);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .pdf-card:hover {
    transform: rotateY(0deg) rotateX(0deg) translateY(-10px);
    box-shadow: 0 25px 50px rgba(0,0,0,0.15);
  }

  .pdf-image-wrapper {
    width: 100%;
    aspect-ratio: 1 / 1.414; /* A4 aspect ratio */
    position: relative;
    border-radius: 12px 12px 0 0;
    overflow: hidden;
  }

  .pdf-cover {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 2.5rem 2rem;
  }

  .pdf-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(26,26,26,0.9) 0%, rgba(26,26,26,0.5) 100%);
  }

  .pdf-logo {
    position: relative;
    z-index: 2;
    color: white;
    font-size: 1.25rem;
    font-weight: 900;
    letter-spacing: -0.5px;
  }

  .pdf-title {
    position: relative;
    z-index: 2;
    color: #fce883;
    font-size: 2.2rem;
    font-weight: 800;
    line-height: 1.1;
    text-align: left;
    text-shadow: 0 4px 12px rgba(0,0,0,0.3);
  }

  .pdf-info {
    padding: 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(0,0,0,0.05);
  }

  .pdf-format {
    font-weight: 700;
    color: var(--text-main);
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  
  .pdf-format::before {
    content: '';
    display: block;
    width: 8px;
    height: 8px;
    background: #e11d48; /* Red for PDF */
    border-radius: 50%;
  }

  .pdf-pages {
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 500;
  }

  /* Utilities */
  .fade-in-up {
    animation: fadeInUp 0.6s cubic-bezier(0.165, 0.84, 0.44, 1) forwards;
    opacity: 0;
    transform: translateY(20px);
  }
  .delay-1 { animation-delay: 0.2s; }

  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }
</style>




